pragma solidity ^0.8.0;

contract Telephone {
    address public owner;

    constructor() {
        owner = msg.sender;
    }

    function changeOwner(address _owner) public {
        if (tx.origin != msg.sender) {  // vulnerability we can do this instead require(msg.sender == owner);
            owner = _owner;
        }
    }
}